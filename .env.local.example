# ─────────────────────────────────────────────────────────────────────────────
# Running OS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Strava API ────────────────────────────────────────────────────────────────
#
# 1. Go to https://www.strava.com/settings/api
# 2. Create a new application (or use an existing one)
# 3. Copy Client ID and Client Secret below
# 4. Set the Authorization Callback Domain to: localhost (dev) or yourdomain.com (prod)

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here

# The full callback URL — must match exactly what's registered in Strava's app settings.
# Development:
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback
# Production (uncomment and fill):
# STRAVA_REDIRECT_URI=https://yourdomain.com/api/strava/callback

# ── Next.js ───────────────────────────────────────────────────────────────────
# Optional: set NEXTAUTH_SECRET if you add NextAuth in the future
# NEXTAUTH_SECRET=your_random_32_char_secret
